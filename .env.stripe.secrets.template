# Local-only secrets for stripe-smoke.js. Copy to .env.stripe.secrets
# (gitignored via the .env.*.secrets pattern) and fill in the values, then:
#
#   source .env.stripe.secrets && node stripe-smoke.js
#
# Or set the vars inline:
#
#   KEFI_OWNER_USER=kefi-owner KEFI_OWNER_PASS='...' node stripe-smoke.js

KEFI_OWNER_USER=kefi-owner
KEFI_OWNER_PASS=
