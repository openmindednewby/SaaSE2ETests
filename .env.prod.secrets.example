# E2E secrets — PROD target. THIS FILE IS A TEMPLATE.
#
# Copy to `.env.prod.secrets` (gitignored) and fill in. Never commit the
# real file. Treat the values as production credentials — rotate per the
# credential-rotation cadence (see personalServerNotes/credential-inventory.yml).
#
# Loaded by fixtures/env-loader.ts AFTER .env.prod, so values here override.

# Production superUser — must have the "superUser" role in the OnlineMenu
# realm (the Phase 2 canary middleware checks this role specifically). The
# global-setup.canary.ts mints a JWT with these creds and stashes it for
# the per-service cleanup endpoints. Anonymous or non-superUser cleanup
# calls are rejected with HTTP 403 INVALID_CANARY_AUTH.
#
# These are NOT the same credentials as KEYCLOAK_STAGING_MASTER_ADMIN_* —
# Keycloak master admin is the cluster-admin escape hatch; the superUser
# below is a regular realm user with the elevated role attached.
TEST_USER_USERNAME=
TEST_USER_PASSWORD=

# Optional: explicit SUPERUSER_* aliases (preferred by global-setup.canary.ts
# when both are set; falls back to TEST_USER_* otherwise).
# SUPERUSER_USERNAME=
# SUPERUSER_PASSWORD=

# Production Keycloak master admin — only needed if a test path drives
# `keycloak-seed-test-users` or similar against prod KC. Standard canary
# suites do NOT need this; leave unset unless wiring Phase 5 ops scripts.
# KEYCLOAK_MASTER_ADMIN_USER=
# KEYCLOAK_MASTER_ADMIN_PASSWORD=

# ── Kefi tenant-lifecycle E2E (Phase B) ──────────────────────────────────
# bff-kefi-client confidential secret. Source on prod:
#   ssh root@10.0.0.4 "kubectl get secret bff-client-secrets -n dloizides -o yaml" \
#     | grep bff-kefi-secret | awk '{print $2}' | base64 -d
# Used for ROPC server-to-server token mints in tests/kefi/.
KEFI_BFF_CLIENT_SECRET=

# Platform-admin test user in the kefi KC realm (seeded by
# scripts/create-kefi-test-users.ps1). Role: kefi-platform-admin.
KEFI_PLATFORM_ADMIN_USERNAME=kefi-platformadmin
KEFI_PLATFORM_ADMIN_PASSWORD=

# Bot mailbox IMAP password. Source on either cluster:
#   ssh root@10.0.0.4 "kubectl get secret e2e-mailbox-secrets -n dloizides \
#     -o jsonpath='{.data.kefi-bot-password}'" | base64 -d
E2E_KEFI_MAILBOX_PASSWORD=
